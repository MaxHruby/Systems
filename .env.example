# ── Supabase (povinné) ─────────────────────────────────────────────
# Supabase → Project Settings → API
SUPABASE_URL="https://XXXXXXXX.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."   # TAJNÉ, jen na serveru

# ── Přístup do appky (doporučené) ──────────────────────────────────
# Když je prázdné, appka je otevřená bez hesla (jen pro lokální dev).
APP_PASSWORD="zvol-si-heslo"

# ── Odesílání emailů (stránka "Psát") ──────────────────────────────
# Gmail: vytvoř App Password na https://myaccount.google.com/apppasswords
# (vyžaduje zapnuté 2FA) a vlož ho do SMTP_PASS (16 znaků, mezery můžeš smazat).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="tvuj.email@gmail.com"
SMTP_PASS=""
SMTP_FROM_NAME="Max Hrubý"
# Volitelný podpis dosazený za {podpis} v šablonách:
OUTREACH_SIGNATURE="Max Hrubý — Systémy & Automatizace"

# ── Engine — Google Maps (volitelné) ───────────────────────────────
# Nech prázdné = používá se jen free zdroj (Firmy z mapy / OpenStreetMap).
# Doplň klíč = ve „Najít firmy" přibude zdroj „Engine — Google Maps".
ENGINE_API_KEY=""
ENGINE_API_BASE_URL="https://engine.zaigla.com"
ENGINE_PROJECT_ID="systems"
ENGINE_SOURCING_SOURCE="apify_google_maps"
# Cesty endpointů (měň jen když se engine API liší)
ENGINE_SOURCING_SEARCH_PATH="/api/v1/lead-sourcing/search"
ENGINE_SOURCING_STATUS_PATH="/api/v1/sourcing/jobs/{jobId}"
ENGINE_SOURCING_RESULTS_PATH="/api/v1/sourcing/jobs/{jobId}/leads"
ENGINE_SOURCING_POLL_INTERVAL_MS="3000"
ENGINE_SOURCING_MAX_WAIT_MS="120000"
ENGINE_SOURCING_PAGE_LIMIT="20"
